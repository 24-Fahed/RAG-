@startuml RAG_Physical_Architecture_Staging
!theme plain
skinparam packageStyle rectangle
skinparam shadowing false
skinparam defaultFontSize 12

title RAG Physical Architecture - Stage 2: Integration Testing

legend right
  **Stage 2: Integration Testing (Staging)**
  Real servers, real models, real data.
  End-to-end testing and parameter tuning.
end legend

node "User PC\nWindows / 32GB RAM\n(Client Machine)" as user {
    rectangle "PU-1\nClient Application\n(client/config/staging.yaml)" as pu1
}

node "Public Server\nLinux / 2GB RAM / 20GB Disk\n(Public IP)" as server {
    rectangle "PU-2\nRAG Server\n(FastAPI, port 8000)\n(server/config/staging.yaml)" as pu2
    rectangle "Milvus Standalone\n(Docker, port 19530)" as milvus
    rectangle "Etcd\n(Docker)" as etcd
    rectangle "MinIO\n(Docker)" as minio
    rectangle "BM25 Index\n(./bm25_data/)" as bm25
    rectangle "SSH Tunnel\nlocalhost:8001 -> GPU:8000" as tunnel
}

node "GPU Server\n(AutoDL)\nRTX 3090/4090 24GB VRAM\n32GB RAM / 50GB Disk" as gpu {
    rectangle "PU-3\nInference Worker\n(FastAPI, port 8000)\n(inference/config/staging.yaml)" as pu3
    rectangle "Model Storage\nLLaMA-3-8B + BERT + BGE\n+ MonoT5 + Recomp (~20GB)" as models
}

pu1 ..> pu2 : HTTPS\n<public_ip>:8000
pu2 ..> tunnel : HTTP\nlocalhost:8001
tunnel ..> pu3 : SSH Tunnel
pu2 ..> milvus : gRPC\nlocalhost:19530
pu2 ..> bm25 : local file
pu3 ..> models : load models

note right of gpu
  **Staging Mode:**
  - Real ML models loaded
  - CUDA device
  - Full RAG pipeline active
  - Parameter tuning enabled
  --
  **GPU Selection Guide:**
  LLaMA-3-8B fp16 = ~16GB VRAM
  + BERT + BGE + MonoT5 + Recomp = ~3GB
  --
  Recommended: RTX 3090 / 4090 (24GB VRAM)
  Budget option: RTX 4080 (16GB) with int8 quantization
end note

@enduml
